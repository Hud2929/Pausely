# Pausely Backend Environment Variables
# Copy this file to .dev.vars and fill in your actual values
# DO NOT commit .dev.vars to version control

# Main JWT secret used for all tables and admin operations
# Must be at least 32 characters, cryptographically random
JWT_SECRET_MAIN=your-jwt-secret-here-min-32-chars

# Users table JWT secret (appended to main secret for user auth)
# Must be at least 32 characters, cryptographically random
JWT_SECRET_USERS=your-users-jwt-secret-here-min-32-chars

# Admin service token for backend admin access
# Generate a strong random password
ADMIN_SERVICE_TOKEN=your-admin-service-token-here

# JWT secret for admin operations
# Must be at least 32 characters, cryptographically random
ADMIN_JWT_SECRET=your-admin-jwt-secret-here-min-32-chars

# Pocket UI viewer password (read-only database access)
POCKET_UI_VIEWER_PASSWORD=your-viewer-password-here

# Pocket UI editor password (read-write database access)
POCKET_UI_EDITOR_PASSWORD=your-editor-password-here

# Mailgun API key for sending emails
# Get this from your Mailgun dashboard
MAILGUN_API_KEY=your-mailgun-api-key-here

# API route configuration (set to your API base path or NA if not used)
API_ROUTE=NA
