// Development Environment Configuration
// NEVER commit real keys here.
// Copy this file and fill in your keys, or set via Xcode build settings.
//
// To set keys locally without modifying this file:
//   1. Duplicate this file as Development.local.xcconfig (gitignored)
//   2. Add real values there
//   3. Update your Xcode scheme to use the local config

PAUSELY_ENVIRONMENT = DEV

// Supabase Configuration
// Get these from your Supabase project: Settings → API
SUPABASE_URL = $(SUPABASE_URL)
SUPABASE_ANON_KEY = $(SUPABASE_ANON_KEY)
